/*
  Cache-Control: public, max-age=0, must-revalidate

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# OG images are emitted as extensionless files; pin the type so social
# scrapers (LinkedIn, Slack, X, Facebook) accept the preview image.
/en/opengraph-image
  Content-Type: image/png
/pl/opengraph-image
  Content-Type: image/png
