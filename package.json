{
  "name": "bartoszgrabski-dev",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:studio": "npm run dev --workspace=apps/studio",
    "build:web": "npm run build --workspace=apps/web",
    "deploy:studio": "npm run deploy --workspace=apps/studio",
    "login:studio": "npm run login --workspace=apps/studio",
    "build:studio": "npm run build --workspace=apps/studio",
    "test": "npm run test --workspace=apps/web",
    "seed": "cd scripts && ts-node --project tsconfig.json seed-sanity.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@sanity/client": "^7.22.0",
    "dotenv": "^17.4.2"
  }
}
