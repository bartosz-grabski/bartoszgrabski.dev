{
  "name": "bartoszgrabski-dev",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:studio": "npm run dev --workspace=apps/studio",
    "build:web": "npm run build --workspace=apps/web",
    "deploy:web": "npm run deploy --workspace=apps/web",
    "deploy:studio": "npm run deploy --workspace=apps/studio",
    "deploy:trigger": "npm run deploy --workspace=apps/deploy-trigger",
    "login:studio": "npm run login --workspace=apps/studio",
    "build:studio": "npm run build --workspace=apps/studio",
    "test": "npm run test --workspace=apps/web",
    "seed": "cd scripts && ts-node --project tsconfig.json seed-sanity.ts"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@sanity/client": "^7.23.0",
    "dotenv": "^17.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.1",
    "ws": "^8.21.0",
    "uuid": "^11.1.1"
  }
}
